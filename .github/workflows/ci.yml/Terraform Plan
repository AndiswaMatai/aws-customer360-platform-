name: Terraform Plan

on:
  pull_request:
    branches: [main]
    paths:
      - "terraform/**"

permissions:
  contents: read
  pull-requests: write

jobs:
  terraform-plan:
    name: Validate & Plan
    runs-on: ubuntu-latest
    strategy:
      matrix:
        environment: [dev, prod]
    steps:
      - uses: actions/checkout@v4

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v3
        with:
          terraform_version: "1.7.5"

      - name: Terraform Format Check
        working-directory: terraform
        run: terraform fmt -check -recursive

      - name: Terraform Init
        working-directory: terraform
        # AWS credentials supplied via repository secrets (AWS_ACCESS_KEY_ID,
        # AWS_SECRET_ACCESS_KEY) in a real deployment — omitted here since
        # this repo has no live AWS account.
        run: terraform init -backend=false

      - name: Terraform Validate
        working-directory: terraform
        run: terraform validate

      - name: Terraform Plan (${{ matrix.environment }})
        working-directory: terraform
        run: |
          terraform plan \
            -var-file="environments/${{ matrix.environment }}.tfvars" \
            -lock=false || echo "Plan requires live AWS credentials — see workflow comments"
        continue-on-error: true

  cost-estimate:
    name: Infracost estimate
    runs-on: ubuntu-latest
    needs: terraform-plan
    steps:
      - uses: actions/checkout@v4
      - name: Infracost breakdown
        run: |
          echo "In a connected environment this step runs 'infracost breakdown --path terraform/'"
          echo "and posts the estimated monthly AWS cost delta as a PR comment, cross-checked"
          echo "against cost_optimization/cost_calculator.py's modelled savings."
